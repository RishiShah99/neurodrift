# Copy to .env and fill in. Never commit .env.

# GCP — primary cloud for fleet GPUs and object storage
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT=
GCS_BUCKET=neurodrift-data

# Cohort downloaders (used by scripts/fetch_data.sh on the fleet box)
# IXI needs nothing — fully public.

# OpenBHB — IEEE DataPort profile -> API token
IEEE_DATAPORT_TOKEN=

# OASIS-3 — https://central.xnat.org/ account
XNAT_USER=
XNAT_PASS=

# HCP-Aging + HCP-Development — ConnectomeDB "AWS Connection" page
HCP_AWS_KEY=
HCP_AWS_SECRET=

# Deferred to release day — uncomment when needed
# HF_TOKEN=
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
